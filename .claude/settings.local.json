{
  "permissions": {
    "allow": [
      "Bash(php artisan *)",
      "Bash(mv *)",
      "Bash(curl -s -o /tmp/book.html -w '%{http_code}\\\\n' https://claude-res.test/book)",
      "Read(//tmp/**)",
      "Bash(curl -sk -o /tmp/book.html -w '%{http_code}\\\\n' https://claude-res.test/book)",
      "Bash(vendor/bin/pint --dirty --format agent)",
      "Bash(curl -sk -c /tmp/cookies -b /tmp/cookies -o /tmp/book.html https://claude-res.test/book)",
      "mcp__laravel-boost__database-schema",
      "mcp__laravel-boost__database-query",
      "mcp__laravel-boost__browser-logs",
      "mcp__laravel-boost__last-error"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "laravel-boost"
  ]
}
